package synchronisation;


public class ThreadA extends Thread {

    private final SharedData sharedData;
    private final int iterations;

    
    public ThreadA(SharedData sharedData, int iterations) {

        this.sharedData = sharedData;
        this.iterations = iterations;
    }

    @Override
    public void run() {

        try {

            for (int iteration = 0;
                 iteration < iterations;
                 iteration++) {

                // FuncA1:
                // A1 = sum from 0 to 500
                long A1 = SumUtility.sumTo(500);

                sharedData.setA1(iteration, A1);

                // FuncA2 depends on B2
                long B2 = sharedData.waitForB2(iteration);

                // FuncA2:
                // A2 = B2 + sum from 0 to 300
                long A2 =
                        B2 + SumUtility.sumTo(300);

                sharedData.setA2(iteration, A2);

                // FuncA3 depends on B3
                long B3 = sharedData.waitForB3(iteration);

                // FuncA3:
                // A3 = B3 + sum from 0 to 400
                long A3 =
                        B3 + SumUtility.sumTo(400);

                sharedData.setA3(iteration, A3);
            }

        } catch (InterruptedException e) {

            System.out.println(
                    "Thread A interrupted"
            );

            Thread.currentThread().interrupt();
        }
    }
}
